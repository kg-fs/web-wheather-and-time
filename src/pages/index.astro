---
import '../styles/global.css';
import Dashboard from '../components/Dashboard.jsx';
import HealthCheck from '../components/HealthCheck.jsx';
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Dashboard - Clima & Tiempo VPS</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;950&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-[#0b0f19] text-slate-100 font-sans min-h-screen relative overflow-x-hidden antialiased">
		
		<div class="absolute inset-0 bg-[linear-gradient(to_right,#0f172a_1px,transparent_1px),linear-gradient(to_bottom,#0f172a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)] opacity-30 pointer-events-none"></div>
		
		<div class="absolute -top-40 left-1/4 w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
		<div class="absolute -top-40 right-1/4 w-[500px] h-[500px] bg-emerald-500/10 rounded-full blur-3xl pointer-events-none"></div>

		<div class="relative min-h-screen flex flex-col justify-between py-12">
			<main class="flex-1 flex flex-col justify-center">
				
				<header class="text-center mb-8 px-4">
					<h1 class="text-4xl md:text-5xl font-black tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-indigo-200 via-slate-100 to-emerald-200">
						Estación de Clima y Tiempo
					</h1>
					<p class="text-slate-400 mt-3 text-sm md:text-base max-w-xl mx-auto font-medium leading-relaxed">
						Monitorea en tiempo real las condiciones meteorológicas y el huso horario de cualquier país del mundo.
					</p>
				</header>

				<Dashboard client:load />

			</main>

			<footer class="w-full px-4">
				<HealthCheck client:load />
			</footer>
		</div>
	</body>
</html>

<style>
	:root {
		font-family: 'Outfit', sans-serif;
	}
	body {
		background-color: #0b0f19;
	}
</style>
